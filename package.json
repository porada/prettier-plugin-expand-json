{
	"name": "prettier-plugin-expand-json",
	"version": "1.0.4",
	"description": "Expand JSON arrays and objects into multi-line format with Prettier",
	"license": "MIT",
	"author": {
		"name": "Dom Porada",
		"email": "dom@dom.engineering",
		"url": "https://dom.engineering"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/porada/prettier-plugin-expand-json.git"
	},
	"keywords": [
		"formatting",
		"json",
		"jsonc",
		"prettier",
		"prettier-plugin"
	],
	"files": [
		"dist/**"
	],
	"type": "module",
	"sideEffects": false,
	"exports": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"engines": {
		"node": ">=20"
	},
	"packageManager": "pnpm@10.30.2",
	"peerDependencies": {
		"prettier": ">=3"
	},
	"devDependencies": {
		"@standard-config/eslint": "^1.6.1",
		"@standard-config/oxlint": "^1.2.2",
		"@standard-config/prettier": "^1.10.0",
		"@standard-config/tsconfig": "^2.0.2",
		"@vitest/coverage-v8": "^4.0.18",
		"eslint": "^10.0.2",
		"husky": "^9.1.7",
		"oxlint": "^1.50.0",
		"oxlint-tsgolint": "^0.15.0",
		"prettier": "^3.8.1",
		"prettier-plugin-sort-json": "^4.2.0",
		"publint": "^0.3.17",
		"tsdown": "^0.20.3",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	},
	"scripts": {
		"build": "tsdown",
		"fix": "pnpm format && pnpm lint",
		"format": "prettier --write --ignore-unknown .",
		"format:check": "prettier --check --ignore-unknown .",
		"lint": "oxlint --fix --report-unused-disable-directives --type-aware --type-check",
		"lint:check": "oxlint --deny-warnings --report-unused-disable-directives --type-aware --type-check",
		"prepack": "pnpm run '/^(format:check|lint:check|test|typecheck)$/' && pnpm build",
		"prepare": "husky",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	}
}
